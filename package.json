{
  "name": "juritj",
  "version": "0.0.1",
  "description": "JURITJ",
  "author": "Cour de Cassation",
  "private": true,
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "format": "prettier \"src/**/*.ts\" --check",
    "start": "npx ts-node src/server.ts",
    "start:dev": "nodemon --watch 'src/**' --ext 'ts,json' --exec 'npx ts-node src/server.ts'",
    "start:prod": "node dist/server.js",
    "start:docker": "docker compose up -d",
    "stop:docker": "docker compose stop",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "fix": "eslint \"src/**/*.ts\" --fix && prettier \"src/**/*.ts\" --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.890.0",
    "axios": "1.12.2",
    "cron": "4.3.3",
    "dbsder-api-types": "2.1.9",
    "dotenv": "16.4.7",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "mongodb": "6.19.0",
    "multer": "2.0.2",
    "pino": "9.9.0",
    "uuid": "11.1.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/multer": "2.0.0",
    "@types/node": "24.5.1",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "6.9.1",
    "@typescript-eslint/parser": "6.9.1",
    "eslint": "8.53.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.1",
    "nodemon": "3.1.10",
    "pino-pretty": "13.1.1",
    "prettier": "3.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  }
}